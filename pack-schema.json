{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Oh My Claude Pack",
  "description": "Theme pack schema for Oh My Claude — bundles colors, spinner verbs, agent personality, and status line into a single installable unit.",
  "type": "object",
  "required": ["id", "name", "version", "author", "description", "layers"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Unique pack identifier (kebab-case)"
    },
    "name": {
      "type": "string",
      "description": "Display name"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "author": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "description": "One-line description shown in pack list"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "i18n": {
      "type": "object",
      "description": "Localized UI strings for install output — all keys optional, falls back to English",
      "properties": {
        "installJokes": { "type": "array", "items": { "type": "string" }, "description": "Random jokes shown during install" },
        "installing": { "type": "string" },
        "installedLayers": { "type": "string" },
        "preview": { "type": "string" },
        "colors": { "type": "string" },
        "packInstalled": { "type": "string" },
        "restart": { "type": "string" },
        "whatsNext": { "type": "string" },
        "restartHint": { "type": "string" },
        "switchAgent": { "type": "string" },
        "inAgentSelector": { "type": "string" },
        "tryAnother": { "type": "string" },
        "resetDefaults": { "type": "string" }
      }
    },
    "layers": {
      "type": "object",
      "properties": {
        "theme": {
          "$ref": "#/definitions/ThemeLayer"
        },
        "spinners": {
          "$ref": "#/definitions/SpinnersLayer"
        },
        "agent": {
          "$ref": "#/definitions/AgentLayer"
        },
        "statusLine": {
          "$ref": "#/definitions/StatusLineLayer"
        },
        "tips": {
          "$ref": "#/definitions/TipsLayer"
        },
        "claudeMd": {
          "$ref": "#/definitions/ClaudeMdLayer"
        },
        "welcome": {
          "$ref": "#/definitions/WelcomeLayer"
        }
      }
    }
  },
  "definitions": {
    "ThemeLayer": {
      "type": "object",
      "description": "Color theme — 16 color tokens for Claude Code",
      "properties": {
        "colors": {
          "type": "object",
          "properties": {
            "claude": { "type": "string" },
            "claudeShimmer": { "type": "string" },
            "promptBorder": { "type": "string" },
            "promptBorderShimmer": { "type": "string" },
            "text": { "type": "string" },
            "inverseText": { "type": "string" },
            "background": { "type": "string" },
            "success": { "type": "string" },
            "error": { "type": "string" },
            "warning": { "type": "string" },
            "permission": { "type": "string" },
            "bashBorder": { "type": "string" },
            "inactive": { "type": "string" },
            "subtle": { "type": "string" },
            "suggestion": { "type": "string" },
            "diffAdded": { "type": "string" },
            "diffRemoved": { "type": "string" }
          }
        }
      }
    },
    "SpinnersLayer": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["replace", "append"],
          "default": "append"
        },
        "verbs": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 10,
          "description": "Themed spinner verb phrases"
        }
      },
      "required": ["mode", "verbs"]
    },
    "AgentLayer": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Agent display name"
        },
        "personality": {
          "type": "string",
          "description": "System prompt personality instructions for the agent"
        },
        "emoji_style": {
          "type": "string",
          "description": "Emoji usage guidelines — which emojis to prefer, frequency, placement"
        }
      },
      "required": ["name", "personality"]
    },
    "StatusLineLayer": {
      "type": "object",
      "properties": {
        "template": {
          "type": "string",
          "description": "Status line template string"
        }
      }
    },
    "TipsLayer": {
      "type": "object",
      "description": "Custom spinner tips (jokes, quotes, fun facts) shown while Claude is thinking",
      "properties": {
        "excludeDefault": {
          "type": "boolean",
          "default": true,
          "description": "If true, only show custom tips. If false, mix with defaults."
        },
        "tips": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 5,
          "description": "Array of tip/joke strings"
        }
      },
      "required": ["tips"]
    },
    "ClaudeMdLayer": {
      "type": "object",
      "description": "Personality injection via ~/.claude/CLAUDE.md — adds themed instructions that Claude reads on every session.",
      "properties": {
        "content": {
          "type": "string",
          "description": "Markdown content to append to user CLAUDE.md"
        }
      },
      "required": ["content"]
    },
    "WelcomeLayer": {
      "type": "object",
      "description": "Custom ASCII art welcome message displayed via a startup hook.",
      "properties": {
        "art": {
          "type": "string",
          "description": "ASCII art string (multi-line)"
        },
        "color": {
          "type": "string",
          "description": "ANSI color code for the art, e.g. '\\033[36m' for cyan"
        }
      },
      "required": ["art"]
    }
  }
}
